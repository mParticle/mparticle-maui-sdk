<?xml version="1.0" encoding="utf-8"?>
<!-- Used by verify-ios-release.sh - script overwrites this at runtime -->
<!-- For manual runs: ensure LocalNuGet/ has packages (run script step 1 or dotnet pack) -->
<configuration>
  <packageSources>
    <clear />
    <add key="local-sdk" value="../../../LocalNuGet" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="maui-nativelibraryinterop" value="https://pkgs.dev.azure.com/xamarin/public/_packaging/maui-nativelibraryinterop/nuget/v3/index.json" />
  </packageSources>
</configuration>
